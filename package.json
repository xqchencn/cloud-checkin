{
  "name": "cloud-checkin",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:wrangler-crons": "node scripts/sync-wrangler-crons.mjs",
    "predev": "npm run sync:wrangler-crons",
    "dev": "node scripts/local-scheduled-dev.mjs",
    "predev:frontend": "npm run sync:wrangler-crons",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "cron:local": "curl \"http://localhost:8787/__scheduled?cron=%2A%2F30+0-15+*+*+*\"",
    "cron:cleanup:local": "curl \"http://localhost:8787/__scheduled?cron=0+17+*+*+*\"",
    "prebuild": "npm run sync:wrangler-crons",
    "build": "vite build --config frontend/vite.config.ts",
    "pretypecheck": "npm run sync:wrangler-crons",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "d1:migrate:local": "wrangler d1 migrations apply cloud-checkin-db --local",
    "d1:migrate:remote": "wrangler d1 migrations apply cloud-checkin-db --remote"
  },
  "dependencies": {
    "lucide-react": "^1.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^6.3.4",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
